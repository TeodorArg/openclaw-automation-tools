{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"rootDir": ".",
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node"],
		"noEmit": true
	},
	"include": ["./index.ts", "./api.ts", "./src/**/*.ts", "./src/**/*.d.ts"],
	"exclude": ["./dist/**", "./node_modules/**", "./src/**/*.test.ts"]
}
